{% comment %}
  Market-aware email marketing consent POC.
  Requires the app proxy configured at /apps/market-doi.
{% endcomment %}

<div class="market-doi-newsletter" style="max-width: {{ block.settings.max_width }}px;">
  {% if block.settings.heading != blank %}
    <h2>{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.body != blank %}
    <p>{{ block.settings.body }}</p>
  {% endif %}

  <form method="post" action="/apps/market-doi/subscribe" data-market-doi-newsletter-form>
    <input
      type="email"
      name="email"
      required
      autocomplete="email"
      placeholder="{{ block.settings.placeholder }}"
      style="width: 100%; box-sizing: border-box; padding: .75rem; margin: .5rem 0;"
    >
    <input type="hidden" name="country" value="{{ localization.country.iso_code }}">
    <input type="hidden" name="source" value="theme-app-extension">

    <button type="submit" style="padding: .75rem 1rem; cursor: pointer; margin-top: .5rem;">
      {{ block.settings.button_label }}
    </button>

    <p data-market-doi-newsletter-result role="status" style="margin-top: .75rem;"></p>
  </form>
</div>

<script>
  (() => {
    const forms = document.querySelectorAll('[data-market-doi-newsletter-form]');
    forms.forEach((form) => {
      if (form.dataset.marketDoiBound) return;
      form.dataset.marketDoiBound = 'true';

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const result = form.querySelector('[data-market-doi-newsletter-result]');
        result.textContent = {{ block.settings.loading_label | json }};

        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' }
          });
          const json = await response.json();
          result.textContent = json.ok ? {{ block.settings.success_label | json }} : (json.error || {{ block.settings.error_label | json }});
        } catch (error) {
          result.textContent = error.message || {{ block.settings.error_label | json }};
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Market DOI newsletter",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe to our newsletter"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Get updates, launches and offers by email."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "you@example.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "loading_label",
      "label": "Loading label",
      "default": "Subscribing…"
    },
    {
      "type": "text",
      "id": "success_label",
      "label": "Success label",
      "default": "Thanks — please check your inbox if confirmation is required in your country."
    },
    {
      "type": "text",
      "id": "error_label",
      "label": "Error label",
      "default": "Sorry, something went wrong. Please try again."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 320,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 520
    }
  ]
}
{% endschema %}
